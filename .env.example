# =============================================================================
# Undangin.studio — Environment Variables Template
# =============================================================================
# Copy this file to `.env.local` and fill in your real credentials.
# NEVER commit `.env.local` to version control.
#
# SECURITY RULE:
#   - NEXT_PUBLIC_ prefix  → exposed to the browser (client bundle)
#   - No prefix            → strictly server-side only (never in client bundle)
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Server-only — NEVER expose to client)
# -----------------------------------------------------------------------------
# Full PostgreSQL connection string with SSL enforced.
# Format: postgresql://[user]:[password]@[host]:[port]/[db]?sslmode=require
DATABASE_URL=postgresql://[user]:[password]@[host]:[port]/[db]?sslmode=require

# -----------------------------------------------------------------------------
# AUTH / SESSION (Server-only — NEVER expose to client)
# -----------------------------------------------------------------------------
# Minimum 32 characters. Generate with: openssl rand -base64 32
JWT_SECRET=[minimum-32-char-random-secret-string]

# -----------------------------------------------------------------------------
# SUPABASE (Split: URL+Anon = public / Service Role = server-only)
# -----------------------------------------------------------------------------
# Project base URL — safe to expose (points to your Supabase project).
NEXT_PUBLIC_SUPABASE_URL=https://[your-supabase-project].supabase.co

# Anonymous (public) key — safe to expose, enforces Row Level Security (RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=[your-anon-key]

# Service Role key — bypasses RLS. MUST remain server-side ONLY.
SUPABASE_SERVICE_ROLE_KEY=[your-secret-service-role-key-never-share]

# -----------------------------------------------------------------------------
# UPSTASH REDIS (Server-only — NEVER expose to client)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://[your-redis-endpoint].upstash.io
UPSTASH_REDIS_REST_TOKEN=[your-token]

# -----------------------------------------------------------------------------
# UPSTASH QSTASH / WORKFLOW (Server-only — NEVER expose to client)
# -----------------------------------------------------------------------------
QSTASH_URL=https://qstash.upstash.io/v1/publish/
QSTASH_TOKEN=[your-token]

# The public-facing URL of this application (used by QStash to call back).
# Example: https://dashboard.undangin.studio
NEXT_PUBLIC_APP_URL=https://[your-app-domain]

# -----------------------------------------------------------------------------
# WHATSAPP BLAST GATEWAY (Server-only — NEVER expose to client)
# -----------------------------------------------------------------------------
# API key from your WA gateway provider (e.g., Fonnte, WA Business API, etc.).
WHATSAPP_GATEWAY_API_KEY=[your-provider-token]
WHATSAPP_GATEWAY_BASE_URL=https://[your-wa-gateway-provider]/api
